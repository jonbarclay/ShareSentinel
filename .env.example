# ============================================================
# ShareSentinel Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Webhook Listener ---
WEBHOOK_HOST_PORT=8000
WEBHOOK_AUTH_SECRET=your-shared-secret-here
DEDUP_TTL_SECONDS=86400

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- PostgreSQL ---
POSTGRES_DB=sharesentinel
POSTGRES_USER=sharesentinel
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- Microsoft Graph API (Azure AD App Registration) ---
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# --- AI Provider ---
# Options: anthropic, openai, gemini
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.0-flash

# AI Settings
AI_TEMPERATURE=0

# --- Processing ---
MAX_FILE_SIZE_BYTES=52428800
MAX_AV_FILE_SIZE_BYTES=1610612736
TEXT_CONTENT_LIMIT=100000
SENSITIVITY_THRESHOLD=4
HASH_REUSE_DAYS=30
MAX_CONCURRENT_AV_JOBS=2

# --- Requeue / Retry ---
# Max times a transient-failed event is retried before permanent failure
MAX_EVENT_RETRIES=3
# Base delay in seconds before requeue (doubles per retry: 60, 120, 240)
REQUEUE_BASE_DELAY_SECONDS=60
# Minutes an event can sit in 'processing' before startup recovery requeues it
STUCK_PROCESSING_TIMEOUT_MINUTES=30

# --- Transcription (Audio/Video Pipeline) ---
TRANSCRIPTION_ENABLED=true
# Graph API transcript retrieval timeout (seconds)
GRAPH_TRANSCRIPT_TIMEOUT_SECONDS=30
# Local Whisper transcription via transcriber container
WHISPER_ENABLED=true
WHISPER_MODEL=base.en
WHISPER_SERVICE_URL=http://transcriber:8090
# Device for Whisper inference (cpu or cuda)
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Notifications ---
# Set to false to disable analyst alert emails (AI detection alerts)
# User notifications (post-disposition emails to file owners) are separate
ANALYST_NOTIFICATION_ENABLED=true
# Comma-separated: email,jira
NOTIFICATION_CHANNELS=email
NOTIFY_ON_FOLDER_SHARE=true
NOTIFY_ON_FAILURE=true

# Email (SMTP)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=sharesentinel@yourorg.com
SMTP_PASSWORD=CHANGE_ME
SMTP_USE_TLS=true
EMAIL_FROM=sharesentinel@yourorg.com
EMAIL_TO=analyst1@yourorg.com,analyst2@yourorg.com

# Jira (Phase 2)
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=sharesentinel@yourorg.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SECOPS
JIRA_ISSUE_TYPE=Task

# --- Security / Remediation ---
SECURITY_EMAIL=security@yourorg.com

# --- User Notifications (post-disposition emails to file owners) ---
# Set to true to enable AI-generated emails to users who shared sensitive files
USER_NOTIFICATION_ENABLED=true
# Override recipient — all user notification emails go to this address instead (dev/testing)
USER_NOTIFICATION_OVERRIDE_EMAIL=
# BCC address — receives a copy of every user notification email
USER_NOTIFICATION_BCC=
# Optional: use a different AI provider for email generation (defaults to AI_PROVIDER)
USER_NOTIFICATION_AI_PROVIDER=

# --- Sharing Link Lifecycle ---
LIFECYCLE_CHECK_INTERVAL_HOURS=24
LIFECYCLE_MAX_DAYS=180

# --- Second-Look AI Review ---
SECOND_LOOK_ENABLED=false
SECOND_LOOK_PROVIDER=gemini
SECOND_LOOK_MODEL=gemini-3.1-pro-preview

# --- Allowlist Enforcement (anonymous sharing control) ---
# Enable weekly enforcement of anonymous sharing allow list
ALLOWLIST_ENFORCEMENT_ENABLED=false
# How often to run scheduled enforcement (hours, default 168 = 7 days)
ALLOWLIST_ENFORCEMENT_INTERVAL_HOURS=168
# Sharing capability to set on allow-listed sites
ALLOWLIST_ENABLED_CAPABILITY=ExternalUserAndGuestSharing
# Sharing capability to set on non-allow-listed sites (blocks anonymous links)
ALLOWLIST_DISABLED_CAPABILITY=ExternalUserSharingOnly
# SharePoint admin site URL (e.g., https://yourtenant-admin.sharepoint.com)
SHAREPOINT_ADMIN_URL=https://yourtenant-admin.sharepoint.com

# Certificate path for Graph API auth (dashboard + worker + lifecycle-cron)
AZURE_CERTIFICATE=./graph-api-cert.pfx
AZURE_CERTIFICATE_PASS=your-certificate-password

# --- Nginx / TLS ---
# Place certificate files in nginx/certs/:
#   sharesentinel.crt  (PEM certificate + chain)
#   sharesentinel.key  (PEM private key)

# --- Authentication ---
# Set to true to explicitly disable authentication (NOT recommended for production)
# AUTH_DISABLED=true

# --- Entra ID SSO (OpenID Connect) ---
OIDC_TENANT_ID=your-entra-tenant-id
OIDC_CLIENT_ID=your-app-registration-client-id
OIDC_CLIENT_SECRET=your-app-registration-client-secret
OIDC_REDIRECT_URI=https://sharesentinel.yourorg.com/api/auth/callback
OIDC_ALLOWED_GROUP_IDS=group-object-id-1,group-object-id-2
# Role-based access control (leave empty to allow all authenticated users full access)
OIDC_ADMIN_GROUP_IDS=admin-group-object-id
OIDC_ANALYST_GROUP_IDS=analyst-group-object-id
SESSION_SECRET_KEY=generate-a-random-64-char-secret

# --- Dashboard ---
DASHBOARD_URL=https://sharesentinel.yourorg.com
ALLOWED_ORIGINS=https://sharesentinel.yourorg.com

# --- Logging ---
LOG_LEVEL=INFO
